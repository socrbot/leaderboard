rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user has the admin role
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    // - Any authenticated user can read their own doc
    // - Users can only write their own doc (role field is immutable by the user themselves)
    // - Admins can read/write any user doc (for role assignment)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin() ||
        (request.auth != null && request.auth.uid == userId &&
         !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // Legacy public collections (existing leaderboard data — keep public for now)
    match /tournaments/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /global_teams/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /tournament_scores/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
